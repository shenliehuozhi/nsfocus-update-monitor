# 绿盟升级监控平台 环境变量模板
# 用法: cp .env.example .env && chmod 600 .env
# 然后填下面两个密钥 (用 openssl rand -hex 32 生成)

# Flask 监听地址
# 容器内必须 0.0.0.0 (否则 docker -p 映射的外部流量进不来)
MONITOR_HOST=0.0.0.0

# Flask 监听端口
MONITOR_PORT=9999

# AES 加密密钥 (渠道配置里的 SMTP 密码 / webhook URL 加密用)
# 生成: openssl rand -hex 32
# ⚠️ 改这个会导致已存储的渠道配置无法解密,需重新填写
MONITOR_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# JWT 签名密钥 (用户登录 token 签名)
# 生成: openssl rand -hex 32
MONITOR_JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# 数据目录 (SQLite 数据库 + 初始密码文件)
MONITOR_DATA_DIR=/app/data

# 日志目录
MONITOR_LOG_DIR=/app/logs

# Flask debug 模式 (生产永远 false)
MONITOR_DEBUG=false

# 可选: 日志级别 (默认 INFO, 可选 DEBUG/INFO/WARNING/ERROR)
# MONITOR_LOG_LEVEL=INFO
